# MongoDB 连接
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=traffic_card_hub

# 国产大模型（OpenAI 兼容接口）。支持：通义千问 / 智谱 GLM / Kimi 等
# 通义千问 DashScope：AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  AI_MODEL=qwen-plus
# 智谱 GLM：       AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4            AI_MODEL=glm-4-plus
# Kimi (Moonshot)：AI_BASE_URL=https://api.moonshot.cn/v1                       AI_MODEL=moonshot-v1-8k
AI_API_KEY=
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-plus

# 抓取方式：true=无头浏览器(Playwright)渲染后抓取；false=直接请求接口
SCRAPE_HEADLESS=true

# 平台 1（chshebei 号卡分发）
P1_NAME=畅行号卡
P1_SHOP_ID=00de96ec16cfec53
P1_BASE_URL=https://260709.chshebei.cn

# 平台 2（hemorn 号卡分发）
P2_NAME=木子号卡
P2_BASE_URL=https://leemuzi.hemorn.cn
